# ProofPack AI — environment template
# Copy to frontend/.env.local and fill in values.

# === Server-only (NEVER prefix with NEXT_PUBLIC_) ===
TATUM_API_KEY=

# === Public (browser visible) ===
NEXT_PUBLIC_SUI_NETWORK=testnet
NEXT_PUBLIC_TATUM_SUI_RPC_URL=https://sui-testnet.gateway.tatum.io

# === Walrus ===
# tatum_storage_api  -> upload via Tatum Storage API (primary)
# walrus_publisher   -> direct PUT to Walrus publisher (fallback / local dev)
WALRUS_UPLOAD_MODE=walrus_publisher
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
# Client-visible aggregator (used by blob links + citation chips)
NEXT_PUBLIC_WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
WALRUS_DEFAULT_EPOCHS=5

# === Sui Move package (fill in after `sui client publish`) ===
NEXT_PUBLIC_PACKAGE_ID=
NEXT_PUBLIC_PROOFPACK_REGISTRY_ID=

# === AI (optional) ===
# claude | openai | mcp | none
AI_PROVIDER=none
AI_API_KEY=
AI_MODEL=

# === Tatum Blockchain MCP (optional, when AI_PROVIDER=mcp) ===
TATUM_MCP_URL=
